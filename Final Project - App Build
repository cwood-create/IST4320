import tkinter as tk
from tkinter import ttk
import sqlite3

# Cordinate the database
sql_connect = sqlite3.connect('orders.db') 
cur = sql_connect.cursor()

# Create the table if it doesn't exist already
cur.execute('''
CREATE TABLE IF NOT EXISTS orders (
    customer_name TEXT,
    food TEXT,
    drink TEXT
)
''')

sql_connect.commit()

# Window setup
main = tk.Tk()

main.title("Grubbin Time!")
main.geometry("500x400")
main.configure(bg="lightyellow")

# Label
title_label = tk.Label(
    main,
    text="(: Grubbin Time! :)",
    font=('helvetica', 22, 'bold'),
    fg="darkred",
    bg="lightyellow"
)
title_label.pack(pady=15)

# Entry for name
name_var = tk.StringVar()

name_label = tk.Label(
    main,
    text="Enter your name:",
    font=('helvetica', 14, 'bold'),
    bg="lightyellow"
)
name_label.pack()

name_entry = tk.Entry(
    main,
    textvariable=name_var,
    font=('calibre', 14, 'normal')
)
name_entry.pack(pady=5)

# Dropdown for food
food = tk.StringVar()

food_label = tk.Label(
    main, 
    text="Choose your food:", 
    font=('helvetica', 14, 'bold'),
    bg="lightyellow"
)
food_label.pack()

food_pick = ttk.Combobox(
    main, 
    width=25,
    textvariable=food
)

food_pick['values'] = (
    'Burger',
    'Pizza', 
    'Tacos', 
    'Fries',
    'Wings'
)
food_pick.current(0)
food_pick.pack(pady=5)

# Dropdown for drink
drink = tk.StringVar()

drink_label = tk.Label(
    main,
    text="Choose your drink:",
    font=('helvetica', 14, 'bold'),
    bg="lightyellow"
)
drink_label.pack()

drink_pick = ttk.Combobox(
    main, 
    width=25,
    textvariable=drink
)

drink_pick = ttk.Combobox(
    main,
    width=25,
    textvariable=drink
)

drink_pick['values'] = (
    'Soda',
    'Lemonade', 
    'Coffee',
    'Milkshake'
)
drink_pick.current(0)
drink_pick.pack(pady=5) 

# Submit button activation 
def submitOrder():
    customer_name = name_var.get()
    selected_food = food_pick.get()
    selected_drink = drink_pick.get()

    # Fill database with order
    query = '''
    INSERT INTO orders(customer_name, food, drink) 
    VALUES (?, ?, ?)
    '''

    cur.execute(query, (customer_name, selected_food, selected_drink))
    sql_connect.commit()

    # Popup window 
    popup = tk.Toplevel(main)

    popup.title("Order Confirmation")
    message = (
        "Thanks " + customer_name + "\n\n" + "Your order:\n" + selected_food + " + " + selected_drink + "\n\nYour food will be ready soon ;)"
    ) 

    popup_label = tk.Label( 
        popup, 
        text=message, 
        font=('calibre', 14, 'normal') 
    ) 
    popup_label.pack(padx=20, pady=20) 

    # Clear entry box
    name_var.set("") 

# Submit button 
submit_button = tk.Button(
    main,
    text="Submit Order",
    font=('calibre', 14, 'normal'),
    bg="green",
    fg="white",
    width=15, 
    height=2,
    cursor="hand2",
    relief="ridge",
    command=submitOrder
)
submit_button.pack(pady=20) 

main.mainloop()
